# BeyondTrust Source Configuration
BEYONDTRUST_BASE_URL=https://your-beyondtrust.example.com
BEYONDTRUST_API_TOKEN=your_api_token_here
# Optional alternative auth (use instead of API token if required)
# BEYONDTRUST_USERNAME=your_username_here
# BEYONDTRUST_PASSWORD=your_password_here
# Optional API key header
# BEYONDTRUST_API_KEY=your_api_key_here

# Optional endpoint overrides
BEYONDTRUST_AUTH_ENDPOINT=/api/public/v3/Auth/SignAppin
BEYONDTRUST_MANAGED_ACCOUNTS_ENDPOINT=/api/public/v3/ManagedAccounts
BEYONDTRUST_DEVICES_ENDPOINT=/api/public/v3/ManagedSystems
BEYONDTRUST_APPLICATIONS_ENDPOINT=/api/public/v3/Applications
BEYONDTRUST_ACCESS_ASSIGNMENTS_ENDPOINT=/api/public/v3/AccessAssignments
# Optional supplemental endpoints
# BEYONDTRUST_USERS_ENDPOINT=/api/public/v3/Users
# BEYONDTRUST_GROUPS_ENDPOINT=/api/public/v3/Groups

# Optional custom headers as JSON object string
# BEYONDTRUST_ADDITIONAL_HEADERS_JSON={"X-Custom-Header":"value"}

# Veza Configuration
VEZA_URL=your-company.veza.com
VEZA_API_KEY=your_veza_api_key_here

# OAA Provider Settings (optional overrides)
PROVIDER_NAME=BeyondTrust
DATASOURCE_NAME=BeyondTrust
